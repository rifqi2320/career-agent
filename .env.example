# Google ADK / Gemini API key.
GOOGLE_API_KEY=

# Optional Vertex AI mode for Google ADK.
# GOOGLE_GENAI_USE_VERTEXAI=1
# GOOGLE_CLOUD_PROJECT=
# GOOGLE_CLOUD_LOCATION=us-central1

# OpenRouter API key - get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Gemini API key used by the optional LiteLLM proxy service.
GEMINI_API_KEY=

# LiteLLM proxy master key - used to authenticate requests to the proxy
LITELLM_MASTER_KEY=

# PostgreSQL
POSTGRES_USER=career
POSTGRES_PASSWORD=
POSTGRES_DB=career_agent
DATABASE_URL=

# RabbitMQ
RABBITMQ_DEFAULT_USER=career
RABBITMQ_DEFAULT_PASS=
MATCH_QUEUE_NAME=career.match_jobs
AMQP_URL=

# Optional GitHub API settings for research_skill_resources
GITHUB_TOKEN=
# Alternative token variable if you already use PAT naming
GITHUB_PAT_TOKEN=
GITHUB_API_BASE=https://api.github.com
GITHUB_TIMEOUT_SECONDS=10
RESOURCE_RESEARCH_TIMEOUT_SECONDS=30
